    {
      "id": "27e91aa2-5687-416c-8f11-99bb6b378a7e",
      "name": "Dados do card",
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
              "name": "esforcoEstimado",
              "type": "string",
              "value": "={{\n(() => {\n const fields = $json.data?.card?.fields || [];\n const f = fields.find(x => (x.field?.id || x.indexName || \"\") === \"esfor_o_estimado\");\n const arr = Array.isArray(f?.array_value)\n ? f.array_value\n : f?.value != null\n ? [f.value]\n : [];\n return arr\n .map(v => (typeof v === \"string\" ? v.trim() : String(v)))\n .filter(Boolean)\n .join(\", \");\n})()\n}}"
            },
            {
              "id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
              "name": "retornoEstimado",
              "type": "string",
              "value": "={{\n(() => {\n const fields = $json.data?.card?.fields || [];\n const f = fields.find(x => (x.field?.id || x.indexName || \"\") === \"retorno_estimado\");\n const arr = Array.isArray(f?.array_value)\n ? f.array_value\n : f?.value != null\n ? [f.value]\n : [];\n return arr\n .map(v => (typeof v === \"string\" ? v.trim() : String(v)))\n .filter(Boolean)\n .join(\", \");\n})()\n}}"
            },
            {
              "id": "c3d4e5f6-a7b8-9012-cdef-123456789012",
              "name": "idProjetoAssociado",
              "type": "string",
              "value": "={{\n(() => {\n const fields = $json.data?.card?.fields || [];\n const action = $('Tarefa criada/atualizada em PRO-02').item.json.body.data.action;\n \n // Determine which field to search for based on action\n let fieldToSearch = \"projeto_associado\";\n \n if (action === \"card.create\") {\n   fieldToSearch = \"id_do_projeto_associado\";\n }\n \n // First, try to find the determined field and get its array_value[0]\n const projetoAssociado = fields.find(x => (x.field?.id || x.indexName || \"\") === fieldToSearch);\n \n if (projetoAssociado?.array_value?.[0] != null) {\n   const value = String(projetoAssociado.array_value[0]).trim();\n   // Check if it's an empty array string\n   if (value !== \"\" && value !== \"[]\") {\n     return value;\n   }\n }\n \n // If not found or array_value doesn't exist, look for the same field's value property\n const idProjeto = fields.find(x => (x.field?.id || x.indexName || \"\") === fieldToSearch);\n \n if (idProjeto?.value != null) {\n   const value = String(idProjeto.value).trim();\n   // Check if it's an empty array string\n   if (value !== \"\" && value !== \"[]\") {\n     return value;\n   }\n }\n \n // If neither is found or both are empty/[], return empty string\n return \"\";\n})()\n}}"
            },
