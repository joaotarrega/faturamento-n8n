    {
      "id": "1f3d1c1d-8f57-4416-a5c6-a9084444addb",
      "name": "Criar query",
      "parameters": {
        "jsCode": "const prioridade = $input.item.json.prioridade;\nconst categoriaId = $input.item.json.categoriaId;\nconst cardId = $('Dados do card').item.json.cardId;\nconst idProjetoAssociado = $('Dados do card').item.json.idProjetoAssociado;\nconst action = $('Tarefa criada/atualizada em PRO-02').item.json.body.data.action;\n\nconst includePrioridade = prioridade !== undefined && \n                          prioridade !== null && \n                          prioridade >= 0 && \n                          prioridade <= 100;\n\nconst isCardCreate = action === \"card.create\";\n\nlet mutation = `mutation UpdateCardFields($cardId: ID!) {`;\n\nif (includePrioridade) {\n  mutation += `\n  updateCardField(input: {card_id: $cardId field_id: \"prioridade\" new_value: \"${prioridade}\"}) {\n    card {id}\n    success\n  }`;\n}\n\nmutation += `\n  updateCardField2: updateCardField(input: {card_id: $cardId field_id: \"categoria_de_prioridade\" new_value: [\"${categoriaId}\"]}) {\n    card {id}\n    success\n  }`;\n\n// Only include projeto_associado update if action is card.create\nif (isCardCreate) {\n  mutation += `\n  updateCardField3: updateCardField(input: {card_id: $cardId field_id: \"projeto_associado\" new_value: \"${idProjetoAssociado}\"}) {\n    card {id}\n    success\n  }`;\n}\n\nmutation += `\n}`;\n\nconst queryVariables = {\n  cardId: cardId\n};\n\nreturn { \n  query: mutation,\n  queryVariables: queryVariables\n};"
      },
      "position": [
        -656,
        400
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
