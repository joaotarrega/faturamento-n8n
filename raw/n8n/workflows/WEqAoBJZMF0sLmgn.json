  "nodes": [
    {
      "id": "481fe81f-632f-4adb-82b2-2f5bbd28172b",
      "name": "When clicking ‘Execute workflow’",
      "parameters": {},
      "position": [
        0,
        560
      ],
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1
    },
    {
      "credentials": {
        "oAuth2Api": {
          "id": "26uKvuUtjVempi2s",
          "name": "Pipefy OAuth2 API"
        }
      },
      "id": "1f065704-609a-4249-9716-c2b9c99e5106",
      "name": "Consultar pipes",
      "parameters": {
        "authentication": "oAuth2",
        "endpoint": "https://api.pipefy.com/graphql",
        "query": "query GetDatabaseRecords($orgId: ID!, $databasePipesId: ID!) {\n  # (Optional) sanity check: fetch org name\n  organization(id: $orgId) {\n    id\n    name\n  }\n\n  # Table (database) metadata + which org it belongs to\n  table(id: $databasePipesId) {\n    id\n    name\n    organization { id name }\n  }\n\n  # The actual records from this database (paginated)\n  table_records(table_id: $databasePipesId, first: 50) {\n    edges {\n      node {\n        id\n        title\n        record_fields {\n          name\n          value\n        }\n      }\n    }\n    pageInfo {\n      endCursor\n      hasNextPage\n    }\n  }\n}\n",
        "variables": "={\n  \"orgId\": \"{{$vars.pipefyOrgId}}\",\n  \"databasePipesId\": \"306594780\"\n}"
      },
      "position": [
        224,
        560
      ],
      "type": "n8n-nodes-base.graphql",
      "typeVersion": 1.1
    },
    {
      "id": "9c40956b-b31a-4495-8c9b-e3473d44a0ef",
      "name": "Listar pipes",
      "parameters": {
        "fieldToSplitOut": "data.table_records.edges",
        "options": {}
      },
      "position": [
        448,
        560
      ],
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1
    },
    {
      "id": "efd8ecc0-c441-4edc-8d37-3e353ddbc9a0",
      "maxTries": 5,
      "name": "Download report",
      "parameters": {
        "options": {
          "response": {
            "response": {
              "outputPropertyName": "downloadedReport",
              "responseFormat": "file"
            }
          }
        },
        "url": "={{ $json.data.pipeReportExport.fileURL }}"
      },
      "position": [
        2016,
        320
      ],
      "retryOnFail": true,
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "waitBetweenTries": 5000
    },
    {
      "disabled": true,
      "id": "275a62f3-72ef-4436-8b94-c6ee00ee0ddc",
      "name": ".xlsx -> .json",
      "parameters": {
        "binaryPropertyName": "downloadedReport",
        "operation": "xlsx",
        "options": {
          "headerRow": true
        }
      },
      "position": [
        0,
