    },
    {
      "id": "d54dc474-7afc-4b1f-9b39-cdae2d4a655d",
      "name": "Criar report do pipe",
      "parameters": {
        "authentication": "oAuth2",
        "endpoint": "https://api.pipefy.com/graphql",
        "query": "mutation CreatePipeReport($input: CreatePipeReportInput!) {\n  createPipeReport(input: $input) {\n    pipeReport {\n      id\n      name\n      fields\n      cardCount\n    }\n  }\n}\n",
        "variables": "={\n  \"input\": {\n    \"name\": \"Full Export {{ $now }}\",\n    \"pipeId\": \"{{ $('Loop nos pipes').item.json.node.record_fields[2].value }}\",\n    \"fields\": [{{ $('Listar colunas do report').item.json.data.pipeReportColumns.map(col => `\"${col.name}\"`)\n  .join(\", \"); }}]\n  }\n}"
      },
      "position": [
        1344,
        320
      ],
      "type": "n8n-nodes-base.graphql",
      "typeVersion": 1.1
    },
    {
      "id": "2f42a399-3802-468a-928a-c98e3614927a",
      "name": "Exportar report",
      "parameters": {
        "authentication": "oAuth2",
        "endpoint": "https://api.pipefy.com/graphql",
        "query": "mutation ExportPipeReport($input: ExportPipeReportInput!) {\n  exportPipeReport(input: $input) {\n    pipeReportExport { id }\n  }\n}",
        "variables": "={\n  \"input\": {\n    \"pipeId\": \"{{ $('Loop nos pipes').item.json.node.record_fields[2].value }}\",\n    \"pipeReportId\": \"{{ $json.data.createPipeReport.pipeReport.id }}\"\n  }\n}\n"
      },
      "position": [
        1568,
        320
      ],
      "type": "n8n-nodes-base.graphql",
      "typeVersion": 1.1
    },
