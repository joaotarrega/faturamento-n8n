      ],
      "type": "n8n-nodes-base.extractFromFile",
      "typeVersion": 1
    },
    {
      "id": "632bf54b-6b33-4334-89fc-4a89f5c8f15b",
      "name": "Delete report",
      "parameters": {
        "authentication": "oAuth2",
        "endpoint": "https://api.pipefy.com/graphql",
        "query": "mutation DeletePipeReport($id: ID!) {\n  deletePipeReport(input: { id: $id }) {\n    success\n  }\n}\n",
        "variables": "={\n  \"id\": \"{{ $('Criar report do pipe').item.json.data.createPipeReport.pipeReport.id }}\"\n}\n"
      },
      "position": [
        2240,
        416
      ],
      "type": "n8n-nodes-base.graphql",
      "typeVersion": 1.1
    },
    {
      "id": "6f9c64d4-6017-4795-9f74-3f2956b87a12",
