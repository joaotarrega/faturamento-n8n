    {
      "id": "96edad7c-6187-44c0-a2b6-cdaf3087a4f8",
      "name": "Listar colunas do report",
      "parameters": {
        "authentication": "oAuth2",
        "endpoint": "https://api.pipefy.com/graphql",
        "query": "query GetAllReportColumns($pipeUuid: String!) {\n  pipeReportColumns(pipeUuid: $pipeUuid) {\n    name   # ← use these in createPipeReport.fields\n  }\n}",
        "variables": "={\"pipeUuid\":\"{{ $('Loop nos pipes').item.json.node.record_fields[4].value }}\"}"
      },
      "position": [
        1120,
