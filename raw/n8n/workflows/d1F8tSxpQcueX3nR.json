      "parameters": {
        "authentication": "genericCredentialType",
        "body": "={{ JSON.stringify((() => {\n  const v = $('Variáveis').item.json;\n\n  // Campo (exclusivo)\n  if (v.campo_alterado_id === 'nome') return { nome: v.novo_valor };\n  if (v.campo_alterado_id === 'cnpj') return { cnpj: v.novo_valor };\n\n  // Fase (exclusivo) -> inativar/ativar via \"ativo\" boolean\n  if (['Ativo', 'Inativo'].includes(v.nova_fase)) {\n    return { ativo: v.nova_fase === 'Ativo' };\n  }\n\n  return {};\n})()) }}",
        "contentType": "raw",
        "genericAuthType": "oAuth2Api",
        "method": "PATCH",
        "options": {
          "response": {
