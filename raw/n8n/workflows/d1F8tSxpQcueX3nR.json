      "parameters": {
        "conditions": {
          "combinator": "and",
          "conditions": [
            {
              "id": "diff_check",
              "leftValue": "=={{ \n  $('Variáveis').item.json.campo_alterado_id\n    ? String($('Variáveis').item.json.novo_valor ?? '')\n    : (\n        ['Ativo','Inativo'].includes($('Variáveis').item.json.nova_fase)\n          ? String($('Variáveis').item.json.nova_fase === 'Ativo')\n          : String($json.items[0].ativo)\n      )\n}}",
              "operator": {
                "name": "filter.operator.notEquals",
                "operation": "notEquals",
                "type": "string"
              },
              "rightValue": "=={{ \n  $('Variáveis').item.json.campo_alterado_id\n    ? String($json.items[0][ $('Variáveis').item.json.campo_alterado_id === 'nome' ? 'nome' : 'documento' ] ?? '')\n    : String($json.items[0].ativo)\n}}"
            }
          ],
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          }
        },
        "options": {}
